	-- ==================== DROPDOWN ====================
	function tab:CreateDropdown(cfg)
		cfg = cfg or {}
		local opts = cfg.Options or {}
		local sel = cfg.Default or opts[1] or ""
		local open = false
		
		local DropdownController = {}
		
		local box = Create("Frame", {
			Size = UDim2.new(1, 0, 0, 36),
			BackgroundColor3 = T.Sf,
			Parent = contentContainer,
			ZIndex = 1
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = box })
		
		local btn3 = Create("TextButton", {
			Size = UDim2.new(1, 0, 1, 0),
			BackgroundTransparency = 1,
			Text = "▼  " .. cfg.Name .. ": " .. sel,
			TextColor3 = T.Tx,
			Font = Enum.Font.GothamSemibold,
			TextSize = 14,
			Parent = box,
			ZIndex = 1
		})
		
		local MAX_LIST_HEIGHT = 260
		
		-- Контейнер списка (в Base, чтобы не обрезался)
		local listContainer = Create("Frame", {
			Size = UDim2.new(0, 0, 0, 0),
			BackgroundColor3 = T.Sf,
			Visible = false,
			Parent = Base,
			ZIndex = 999,
			BorderSizePixel = 0
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = listContainer })
		Create("UIStroke", { Thickness = 1.5, Color = T.Tx, Parent = listContainer })
		
		-- ScrollingFrame для опций
		local listScroll = Create("ScrollingFrame", {
			Size = UDim2.new(1, -4, 1, -4),
			Position = UDim2.new(0, 2, 0, 2),
			BackgroundTransparency = 1,
			ScrollBarThickness = 4,
			ScrollBarImageColor3 = T.Tx2,
			CanvasSize = UDim2.new(0, 0, 0, 0),
			AutomaticCanvasSize = Enum.AutomaticSize.Y,
			ScrollingDirection = Enum.ScrollingDirection.Y,
			Parent = listContainer,
			ZIndex = 999
		})
		
		-- UIListLayout для опций
		local listLayout = Create("UIListLayout", {
			Padding = UDim.new(0, 2),
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = listScroll
		})
		
		-- Обновление позиции и размера
		local function UpdateSize()
			local totalH = listLayout.AbsoluteContentSize.Y + 4
			local finalH = math.min(totalH, MAX_LIST_HEIGHT)
			
			local bp = box.AbsolutePosition
			local bs = box.AbsoluteSize
			local screenH = GS:GetScreenResolution().Y
			
			-- Если не влезает снизу - показываем сверху
			if bp.Y + bs.Y + 3 + finalH > screenH then
				listContainer.Position = UDim2.new(0, bp.X, 0, bp.Y - finalH - 3)
			else
				listContainer.Position = UDim2.new(0, bp.X, 0, bp.Y + bs.Y + 3)
			end
			
			listContainer.Size = UDim2.new(0, bs.X, 0, finalH)
			listScroll.CanvasSize = UDim2.new(0, 0, 0, totalH)
		end
		
		-- Построение опций
		local optionButtons = {}
		local function BuildOptions()
			for _, ob in ipairs(optionButtons) do
				pcall(function() ob:Destroy() end)
			end
			optionButtons = {}
			
			for _, o in ipairs(opts) do
				local ob = Create("TextButton", {
					Size = UDim2.new(1, -4, 0, 28),
					BackgroundColor3 = T.Sf2,
					Text = o,
					TextColor3 = T.Tx2,
					Font = Enum.Font.GothamSemibold,
					TextSize = 13,
					Parent = listScroll,
					ZIndex = 999
				})
				Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = ob })
				
				ob.MouseButton1Click:Connect(function()
					sel = o
					btn3.Text = "▼  " .. cfg.Name .. ": " .. sel
					DropdownController:Close()
					if cfg.Callback then
						pcall(cfg.Callback, sel)
					end
				end)
				
				table.insert(optionButtons, ob)
			end
		end
		BuildOptions()
		
		listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			if open then UpdateSize() end
		end)
		
		function DropdownController:Open()
			CloseAllDropdowns(DropdownController)
			open = true
			UpdateSize()
			listContainer.Visible = true
			btn3.Text = "▲  " .. cfg.Name .. ": " .. sel
		end
		
		function DropdownController:Close()
			open = false
			listContainer.Visible = false
			btn3.Text = "▼  " .. cfg.Name .. ": " .. sel
		end
		
		function DropdownController:GetValue()
			return sel
		end
		
		function DropdownController:SetOptions(newOpts)
			opts = newOpts or {}
			BuildOptions()
			if open then UpdateSize() end
		end
		
		btn3.MouseButton1Click:Connect(function()
			if open then
				DropdownController:Close()
			else
				DropdownController:Open()
			end
		end)
		
		-- Клик вне списка
		UIS.InputBegan:Connect(function(input)
			if open and input.UserInputType == Enum.UserInputType.MouseButton1 then
				local m = UIS:GetMouseLocation()
				local lp = listContainer.AbsolutePosition
				local ls = listContainer.AbsoluteSize
				local bp2 = box.AbsolutePosition
				local bs2 = box.AbsoluteSize
				
				if (m.X < lp.X or m.X > lp.X + ls.X or m.Y < lp.Y or m.Y > lp.Y + ls.Y) and
				   (m.X < bp2.X or m.X > bp2.X + bs2.X or m.Y < bp2.Y or m.Y > bp2.Y + bs2.Y) then
					DropdownController:Close()
				end
			end
		end)
		
		DropdownController._box = box
		table.insert(AllDropdowns, DropdownController)
		
		return DropdownController
	end
	
	-- ==================== COLOR PICKER ====================
	function tab:CreateColorPicker(cfg)
		cfg = cfg or {}
		local col = cfg.Default or Color3.new(1, 1, 1)
		local ColorPickerController = {}
		
		local box = Create("Frame", {
			Size = UDim2.new(1, 0, 0, 54),
			BackgroundColor3 = T.Sf,
			Parent = contentContainer
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = box })
		
		Create("TextLabel", {
			Size = UDim2.new(1, -24, 0, 20),
			Position = UDim2.new(0, 14, 0, 4),
			BackgroundTransparency = 1,
			Text = cfg.Name or "Color",
			TextColor3 = T.Tx,
			Font = Enum.Font.GothamSemibold,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = box
		})
		
		local pf = Create("Frame", {
			Size = UDim2.new(1, -28, 0, 28),
			Position = UDim2.new(0, 14, 0, 24),
			BackgroundTransparency = 1,
			Parent = box
		})
		
		Create("UIListLayout", {
			FillDirection = Enum.FillDirection.Horizontal,
			Padding = UDim.new(0, 7),
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = pf
		})
		
		local presets = {
			Color3.new(1, 1, 1),
			Color3.new(0.7, 0.7, 0.7),
			Color3.new(0.5, 0.5, 0.5),
			Color3.new(0.3, 0.3, 0.3),
			Color3.new(1, 0.3, 0.3),
			Color3.new(0.3, 1, 0.3),
			Color3.new(0.3, 0.3, 1)
		}
		
		local selFrame = nil
		for _, p in ipairs(presets) do
			local cb = Create("TextButton", {
				Size = UDim2.new(0, 24, 0, 24),
				BackgroundColor3 = p,
				Text = "",
				Parent = pf
			})
			Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = cb })
			
			if p == col then
				Create("UIStroke", { Thickness = 2, Color = T.Tx, Parent = cb })
				selFrame = cb
			end
			
			cb.MouseButton1Click:Connect(function()
				if selFrame then
					local s = selFrame:FindFirstChildOfClass("UIStroke")
					if s then s:Destroy() end
				end
				Create("UIStroke", { Thickness = 2, Color = T.Tx, Parent = cb })
				selFrame = cb
				col = p
				if cfg.Callback then
					pcall(cfg.Callback, col)
				end
			end)
		end
		
		function ColorPickerController:GetColor()
			return col
		end
		
		ColorPickerController._box = box
		return ColorPickerController
	end
	
	-- ==================== TEXTBOX ====================
	function tab:CreateTextBox(cfg)
		cfg = cfg or {}
		local TextBoxController = {}
		
		local box = Create("Frame", {
			Size = UDim2.new(1, 0, 0, 42),
			BackgroundColor3 = T.Sf,
			Parent = contentContainer
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = box })
		
		local inp = Create("TextBox", {
			Size = UDim2.new(1, -28, 0, 30),
			Position = UDim2.new(0, 14, 0, 6),
			BackgroundColor3 = T.Sf2,
			Text = cfg.Default or "",
			PlaceholderText = cfg.Placeholder or "Enter text...",
			TextColor3 = T.Tx,
			PlaceholderColor3 = T.Tx2,
			Font = Enum.Font.GothamSemibold,
			TextSize = 14,
			ClearTextOnFocus = false,
			Parent = box
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = inp })
		
		inp.FocusLost:Connect(function(enter)
			if cfg.Callback then
				pcall(cfg.Callback, inp.Text, enter)
			end
		end)
		
		function TextBoxController:GetText()
			return inp.Text
		end
		
		function TextBoxController:SetText(text)
			inp.Text = text
		end
		
		TextBoxController._box = box
		return TextBoxController
	end
	
	-- Добавляем вкладку в список
	table.insert(self.Tabs, tab)
	
	-- Авто-активация первой вкладки
	if #self.Tabs == 1 then		contentContainer.Visible = true
		btn.BackgroundColor3 = T.Tx2
		btn.TextColor3 = T.Bg
		self.CurrentTab = tab
	end
	
	return tab
end

-- ==================== ГЛОБАЛЬНЫЕ ФУНКЦИИ ====================
function NekoUI:CreateWindow(cfg)
	local w = Window.new(cfg)
	table.insert(Library.Windows, w)
	return w
end

function NekoUI:AddTheme(name, t)
	Library.Themes[name] = t
end

return NekoUI
